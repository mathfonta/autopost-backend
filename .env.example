# ════════════ AutoPost Backend — Variáveis de Ambiente ════════════
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório

# ─── App ─────────────────────────────────────────────────────
ENV=development
APP_VERSION=1.0.0

# ─── Banco de Dados (Supabase) ────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # Settings → API → service_role key

# ─── Redis (Railway add-on) ───────────────────────────────────
# Encontre em: Railway → seu projeto → Redis → Connect
REDIS_URL=redis://default:[PASSWORD]@[HOST]:[PORT]

# ─── Auth ────────────────────────────────────────────────────
# Gere um secret seguro: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=seu_jwt_secret_aqui
JWT_EXPIRE_MINUTES=60

# ─── Cloudflare R2 ───────────────────────────────────────────
# Encontre em: Cloudflare Dashboard → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_BUCKET=autopost-media
CLOUDFLARE_R2_ACCESS_KEY=sua_access_key
CLOUDFLARE_R2_SECRET_KEY=seu_secret_key
CLOUDFLARE_R2_ENDPOINT=https://[ACCOUNT_ID].r2.cloudflarestorage.com

# ─── IA (Anthropic) ──────────────────────────────────────────
# Encontre em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── IA — Providers plugáveis ────────────────────────────────
TRANSCRIPTION_PROVIDER=gemini   # "gemini" | "whisper"
COPY_PROVIDER=claude            # "claude" | "gemini"
GEMINI_API_KEY=                 # Obter em: aistudio.google.com → API Keys

# ─── Exa Search (inteligência de mercado) ────────────────────
# Obter em: exa.ai → Signup → API Keys (free tier: 1.000 req/mês)
EXA_PROVIDER=disabled           # "exa" | "disabled" — desativado por padrão
EXA_API_KEY=                    # Preencher ao ativar EXA_PROVIDER=exa

# ─── Meta (Instagram + Facebook + WhatsApp) ──────────────────
# Encontre em: developers.facebook.com → seu App → Tokens
META_ACCESS_TOKEN=EAAUcv...
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_VERIFY_TOKEN=um_token_secreto_que_voce_escolhe

# ─── Add-ons (opcionais) ─────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
